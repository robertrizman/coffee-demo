{
  "expo": {
    "name": "Tealium Arc Cafe",
    "slug": "tealium-coffee-demo",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "coffeedemo",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.robrizzy.coffeecafe",
      "entitlements": {
        "aps-environment": "production"
      },
      "infoPlist": {
        "CFBundleDisplayName": "Tealium Arc Cafe",
        "NSCameraUsageDescription": "Allow Tealium Arc Cafe to access your camera to scan order QR codes.",
        "NSLocationWhenInUseUsageDescription": "We need your location to confirm you are at the venue to place an order.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "We need your location to confirm you are at the venue to place an order.",
        "NSUserNotificationsUsageDescription": "We'll notify you when your coffee order is ready for pickup"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.tealium.coffeecafe",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "CAMERA",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Tealium Arc Cafe to access your camera to scan order QR codes."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#FFFFFF",
          "sounds": []
        }
      ],
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e0b60245-0625-41bc-a4b5-248e50f54c91"
      }
    }
  }
}
